{
  "name": "nova-launcher",
  "version": "1.0.0",
  "description": "A fast, offline Minecraft launcher built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.nova.launcher",
    "productName": "Nova Launcher",
    "icon": "assets/icon",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": []
  },
  "keywords": ["minecraft", "launcher", "electron", "offline", "cracked"],
  "author": "Negro-boi",
  "license": "MIT",
  "dependencies": {
    "minecraft-launcher-core": "^3.9.0",
    "node-fetch": "^2.7.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0",
    "axios": "^1.6.0",
    "archiver": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}